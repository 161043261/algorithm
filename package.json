{
  "author": "github.com/161043261",
  "description": "Algorithms implemented by JS/TS/C++/Python",
  "keywords": [],
  "license": "ISC",
  "lint-staged": {
    "*.{json,jsonc,js,cjs,mjs,jsx,ts,cts,mts,tsx,html,vue,css,scss,md,mdx}": [
      "pnpm format",
      "pnpm lint"
    ]
  },
  "name": "algorithm",
  "packageManager": "pnpm@10.13.1",
  "private": true,
  "repository": "git@github.com:161043261/algorithm",
  "scripts": {
    "compile": "tsc",
    "cmake": "cmake -S ./ -B ./build && cmake --build ./build",
    "format": "prettier --write ./src ./vite ./webpack",
    "lint": "eslint ./src",
    "index:js": "node ./src/index.js",
    "index:ts": "tsc && node ./dist/src/index.js",
    "prepare": "husky",
    "webpack:dev": "webpack-dev-server --config ./webpack/webpack.dev.js",
    "webpack:build": "webpack --config ./webpack/webpack.prod.js",
    "vite:dev": "vite --config ./vite/vite.config.ts",
    "vite:build": "tsc -b && vite build --config ./vite/vite.config.ts"
  },
  "type": "module",
  "version": "1.0.0",
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "compression-webpack-plugin": "^11.1.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-vue": "~10.5.0",
    "globals": "^16.3.0",
    "html-webpack-plugin": "^5.6.4",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.1.5",
    "lodash-webpack-plugin": "^0.11.6",
    "mobx": "^6.15.0",
    "npm-run-all2": "^8.0.4",
    "pinia": "^3.0.3",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.1.1",
    "react-router": "^7.9.5",
    "react-router-dom": "^7.9.5",
    "style-loader": "^4.0.0",
