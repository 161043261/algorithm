{
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chat.editor.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "chat.editor.fontSize": 16,
  "chat.viewSessions.orientation": "stacked",
  "clangd.arguments": ["--clang-tidy"],
  "cmakeIntelliSence.cmakePath": "/opt/homebrew/bin/cmake",
  "debug.console.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "debug.console.fontSize": 16,
  "debug.onTaskErrors": "abort",
  "docker.extension.enableComposeLanguageServer": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.codeActionsOnSave": {},
  "editor.codeActionWidget.includeNearbyQuickFixes": false,
  "editor.codeLensFontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "editor.codeLensFontSize": 16,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.dropIntoEditor.preferences": [],
  "editor.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.indentSize": "tabSize",
  "editor.inlayHints.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "editor.inlayHints.fontSize": 16,
  "editor.inlineSuggest.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "editor.lineHeight": 1.3,
  "editor.minimap.enabled": false,
  "editor.minimap.sectionHeaderFontSize": 16,
  "editor.mouseWheelZoom": true,
  "editor.smoothScrolling": true,
  "editor.suggestFontSize": 16,
  "editor.tabSize": 2,
  "editor.trimAutoWhitespace": true,
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "files.autoSave": "afterDelay",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",
  "github.copilot.enable": {
    "*": false
  },
  "gitlens.views.scm.grouped.views": {
    "branches": true,
    "commits": true,
    "contributors": true,
    "fileHistory": false,
    "launchpad": false,
    "remotes": true,
    "repositories": true,
    "searchAndCompare": true,
    "stashes": true,
    "tags": true,
    "worktrees": true
  },
  "go.toolsManagement.autoUpdate": true,
  "js.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.trustedDomains": {
    "https://biomejs.dev": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true
  },
  "makefile.configureOnOpen": true,
  "markdown.preview.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "markdown.preview.fontSize": 16,
  "notebook.formatOnCellExecution": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.markup.fontSize": 16,
  "notebook.output.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "notebook.output.fontSize": 16,
  "notebook.output.wordWrap": true,
  "prettier.endOfLine": "lf",
  "prettier.tabWidth": 2,
  "python.analysis.autoIndent": true,
  "python.analysis.typeCheckingMode": "standard",
  "redhat.telemetry.enabled": true,
  "remote.SSH.remotePlatform": {},
  "scm.inputFontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "scm.inputFontSize": 16,
  "screencastMode.fontSize": 24,
  "security.promptForLocalFileProtocolHandling": false,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.external.linuxExec": "zsh",
  "terminal.external.osxExec": "zsh",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "Iosevka, Cascadia Code, Menlo, LXGW WenKai, PingFang SC, Microsoft YaHei",
  "terminal.integrated.fontSize": 16,
  "ts.updateImportsOnFileMove.enabled": "always",
  "workbench.colorTheme": "Catppuccin Latte",
  "workbench.editor.wrapTabs": true,
  "workbench.iconTheme": "catppuccin-latte",
  "workbench.list.smoothScrolling": true
}
